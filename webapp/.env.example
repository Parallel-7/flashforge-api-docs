# FlashForge Web App — Configurazione
# Copia questo file in .env e compila i valori

# Indirizzo IP della stampante in rete locale
PRINTER_IP=192.168.1.100

# Numero di serie della stampante (es. SN-XXXXXX)
# Reperibile sull'etichetta della stampante o nell'app FlashForge
SERIAL_NUMBER=your_serial_number_here

# CheckCode per autenticazione API locale
# Reperibile nell'app FlashForge: Dispositivo → Impostazioni → Connessione LAN
CHECK_CODE=your_check_code_here

# Porta su cui gira questa web app
PORT=3000
